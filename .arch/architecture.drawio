        <mxCell id="flow1" value="① CHAT&#10;Cliente → /api/v1/chat → ChatUseCase&#10;→ factory.get_agent_runner() → LangChain/Agno&#10;→ tools (search_kb, score_credit) → LLM provider&#10;→ resposta + trace OTel → Tempo + Langfuse" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="860" width="360" height="180" as="geometry" />
        </mxCell>
        <mxCell id="flow2" value="② SCORE DE CRÉDITO&#10;Simulador/WhatsApp → /api/v1/score&#10;→ ScoreCreditUseCase → SklearnCreditScorer&#10;→ features (LTV, DTI, idade) → GradientBoosting&#10;→ risk_factors + explanation (regulatório BACEN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="440" y="860" width="360" height="180" as="geometry" />
        </mxCell>
        <mxCell id="flow3" value="③ INGESTÃO RAG&#10;Admin SPA → /api/v1/ingest/{url,doc}&#10;→ Crawl4AI/Docling → chunking&#10;→ factory.get_embeddings() (provider do .env)&#10;→ get_vector_store() → Chroma/FAISS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="820" y="860" width="360" height="180" as="geometry" />
        </mxCell>
        <mxCell id="flow4" value="④ BUSCA SEMÂNTICA&#10;Admin/Agente → /api/v1/search?q=&#10;→ SearchUseCase → VectorStore.search(k=RAG_TOP_K)&#10;→ top-K chunks + score&#10;→ (opcional) Cohere Rerank → resposta" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1200" y="860" width="340" height="180" as="geometry" />
