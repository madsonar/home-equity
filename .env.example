# ──────────────────────────────────────────────
#  LLM Providers — preencha a API key do provider escolhido
# ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
DEEPSEEK_API_KEY=...
COHERE_API_KEY=...

# Provider ATIVO (chat + score) — openai | google | deepseek | cohere
DEFAULT_LLM_PROVIDER=google
DEFAULT_LLM_MODEL=gemini-2.5-pro
DEFAULT_LLM_TEMPERATURE=0.0

# Embeddings — google | openai | cohere | local (HuggingFace)
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=models/text-embedding-004
LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Agente default do /chat — langchain | agno
DEFAULT_AGENT=langchain

# ──────────────────────────────────────────────
#  Vector Stores
# ──────────────────────────────────────────────
VECTOR_STORE_BACKEND=chroma          # chroma | faiss
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_PERSIST_PATH=./data/chroma_db
CHROMA_COLLECTION=credit_knowledge_base
FAISS_INDEX_PATH=./data/faiss_index
LLAMA_COLLECTION=llama_credit_index
RAG_TOP_K=4

# ──────────────────────────────────────────────
#  Redis / Memory
# ──────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
MEMORY_COLLECTION_PREFIX=memory_
SHORT_TERM_MEMORY_WINDOW=10

# ──────────────────────────────────────────────
#  ML / Credit Scorer
# ──────────────────────────────────────────────
CREDIT_MODEL_PATH=./data/credit_model.pkl

# ──────────────────────────────────────────────
#  App
# ──────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
KNOWLEDGE_BASE_PATH=./data/knowledge_base

# ──────────────────────────────────────────────
#  Observabilidade — OpenTelemetry + Langfuse
# ──────────────────────────────────────────────
# Para usar a stack local de monitoring (perfil "monitoring" do docker-compose),
# mantenha OTLP_ENDPOINT apontando para o otel-collector:
OTLP_ENDPOINT=http://otel-collector:4317

# Langfuse — use a stack local (perfil "langfuse") ou o cloud.langfuse.com.
# Para a stack local, gere as chaves via UI em http://localhost:3000 depois do 1º login.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://langfuse:3000       # use https://cloud.langfuse.com p/ SaaS

# Grafana (perfil "monitoring")
GRAFANA_USER=
GRAFANA_PASSWORD=

# ──────────────────────────────────────────────
#  WhatsApp / Twilio
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=+14155238886       # número sandbox Twilio

# ──────────────────────────────────────────────
#  Snowflake (dados reais de crédito)
# ──────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=org-account
SNOWFLAKE_USER=svc_cashme
SNOWFLAKE_PASSWORD=...
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=CASHME_DW
SNOWFLAKE_SCHEMA=PUBLIC
