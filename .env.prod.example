# ──────────────────────────────────────────────
#  CashMe — variáveis de PRODUÇÃO (VM única AWS)
#
#  Copie para `.env.prod` e preencha. NUNCA comite `.env.prod`.
#  O Ansible envia este arquivo do controlador para `/srv/cashme/repo/.env`
#  na VM. Variáveis ausentes caem para defaults do docker-compose.
# ──────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
COHERE_API_KEY=

DEFAULT_LLM_PROVIDER=google
DEFAULT_LLM_MODEL=gemini-2.5-flash
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=models/gemini-embedding-001

# ── Web search (opcional) ────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
# OBRIGATÓRIO trocar — gere com: openssl rand -hex 48
JWT_SECRET_KEY=change-me-please-generate-with-openssl-rand-hex-48
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=1440

# ── Backoffice ───────────────────────────────────────────────────────────────
SIMULATION_ANALYST_THRESHOLD=100000
EPHEMERAL_INDEX_TTL_SECONDS=7200

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# ── Observabilidade ──────────────────────────────────────────────────────────
# Apague ou aponte para http://otel-collector:4317 se subir profile monitoring.
OTLP_ENDPOINT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# ── Profiles do compose ──────────────────────────────────────────────────────
# Vazio = só o stack default (app/db/redis/chromadb).
# Para subir extras: COMPOSE_PROFILES=monitoring,langfuse
COMPOSE_PROFILES=

# ── Reverse proxy Caddy ──────────────────────────────────────────────────────
# Basic-Auth global na porta 80. Se ausente, o Ansible gera senha aleatória
# e salva em ~/.cashme-ops/panel-password.txt no controlador.
PANEL_BASIC_AUTH_USER=admin
PANEL_BASIC_AUTH_PASS=

# ── Integrações opcionais ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
