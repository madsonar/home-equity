{
  "title": "Logs — Loki Overview",
  "uid": "cashme-logs",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["cashme", "logs", "loki"],
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": {"type": "loki", "uid": "loki"},
        "query": "label_values(container)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "Linhas/min por container",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum by (container) (rate({container=~\"$container\"}[1m]))", "legendFormat": "{{container}}"}]
    },
    {
      "id": 2, "type": "timeseries", "title": "Erros (linhas com level=error / ERROR / WARN)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "sum by (container) (rate({container=~\"$container\"} |~ \"(?i)\\\\b(error|exception|traceback)\\\\b\" [1m]))", "legendFormat": "error {{container}}"},
        {"expr": "sum by (container) (rate({container=~\"$container\"} |~ \"(?i)\\\\bwarn(ing)?\\\\b\" [1m]))", "legendFormat": "warn {{container}}"}
      ]
    },
    {
      "id": 3, "type": "stat", "title": "Total nas últimas 24h",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"expr": "sum(count_over_time({container=~\"$container\"}[24h]))"}]
    },
    {
      "id": 4, "type": "logs", "title": "Logs recentes",
      "gridPos": {"h": 14, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "loki", "uid": "loki"},
      "options": {"showTime": true, "wrapLogMessage": true, "sortOrder": "Descending"},
      "targets": [{"expr": "{container=~\"$container\"}"}]
    }
  ]
}
