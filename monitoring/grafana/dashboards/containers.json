{
  "title": "Containers — cAdvisor",
  "uid": "cashme-containers",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["cashme", "containers", "cadvisor"],
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "CPU por container",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "targets": [{"expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"cashme-.+\"}[2m]))", "legendFormat": "{{name}}"}]
    },
    {
      "id": 2, "type": "timeseries", "title": "Memória RSS por container",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "targets": [{"expr": "container_memory_rss{name=~\"cashme-.+\"}", "legendFormat": "{{name}}"}]
    },
    {
      "id": 3, "type": "timeseries", "title": "Memória Working Set por container",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "targets": [{"expr": "container_memory_working_set_bytes{name=~\"cashme-.+\"}", "legendFormat": "{{name}}"}]
    },
    {
      "id": 4, "type": "timeseries", "title": "Network rx/tx por container",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "targets": [
        {"expr": "rate(container_network_receive_bytes_total{name=~\"cashme-.+\"}[5m])", "legendFormat": "rx {{name}}"},
        {"expr": "rate(container_network_transmit_bytes_total{name=~\"cashme-.+\"}[5m])", "legendFormat": "tx {{name}}"}
      ]
    },
    {
      "id": 5, "type": "timeseries", "title": "Filesystem usage",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "targets": [{"expr": "container_fs_usage_bytes{name=~\"cashme-.+\"}", "legendFormat": "{{name}}"}]
    },
    {
      "id": 6, "type": "table", "title": "Containers ativos",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 27},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "count by (name) (container_last_seen{name=~\"cashme-.+\"})", "format": "table", "instant": true}]
    }
  ]
}
